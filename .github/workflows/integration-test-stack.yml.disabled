AWSTemplateFormatVersion: '2010-09-09'
Description: Integration test infrastructure for AWS Durable Execution SDK Rust

Parameters:
  DeploymentBucket:
    Type: String
    Description: S3 bucket containing Lambda deployment packages
  SimpleWorkflowKey:
    Type: String
    Description: S3 key for simple workflow Lambda package
  ParallelProcessingKey:
    Type: String
    Description: S3 key for parallel processing Lambda package
  CallbackWorkflowKey:
    Type: String
    Description: S3 key for callback workflow Lambda package

Resources:
  LambdaExecutionRole:
    Type: AWS::IAM::Role
    Properties:
      AssumeRolePolicyDocument:
        Version: '2012-10-17'
        Statement:
          - Effect: Allow
            Principal:
              Service: lambda.amazonaws.com
            Action: sts:AssumeRole
      ManagedPolicyArns:
        - arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole
      Policies:
        - PolicyName: DurableExecutionPolicy
          PolicyDocument:
            Version: '2012-10-17'
            Statement:
              - Effect: Allow
                Action:
                  - states:*
                  - lambda:InvokeFunction
                Resource: '*'

  SimpleWorkflowFunction:
    Type: AWS::Lambda::Function
    Properties:
      FunctionName: !Sub '${AWS::StackName}-simple-workflow'
      Runtime: provided.al2
      Handler: bootstrap
      Role: !GetAtt LambdaExecutionRole.Arn
      Code:
        S3Bucket: !Ref DeploymentBucket
        S3Key: !Ref SimpleWorkflowKey
      Timeout: 300
      MemorySize: 256

  ParallelProcessingFunction:
    Type: AWS::Lambda::Function
    Properties:
      FunctionName: !Sub '${AWS::StackName}-parallel-processing'
      Runtime: provided.al2
      Handler: bootstrap
      Role: !GetAtt LambdaExecutionRole.Arn
      Code:
        S3Bucket: !Ref DeploymentBucket
        S3Key: !Ref ParallelProcessingKey
      Timeout: 300
      MemorySize: 512

  CallbackWorkflowFunction:
    Type: AWS::Lambda::Function
    Properties:
      FunctionName: !Sub '${AWS::StackName}-callback-workflow'
      Runtime: provided.al2
      Handler: bootstrap
      Role: !GetAtt LambdaExecutionRole.Arn
      Code:
        S3Bucket: !Ref DeploymentBucket
        S3Key: !Ref CallbackWorkflowKey
      Timeout: 300
      MemorySize: 256

Outputs:
  SimpleWorkflowFunction:
    Value: !Ref SimpleWorkflowFunction
  ParallelProcessingFunction:
    Value: !Ref ParallelProcessingFunction
  CallbackWorkflowFunction:
    Value: !Ref CallbackWorkflowFunction
